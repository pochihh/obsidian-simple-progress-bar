{
  "name": "obsidian-simple-progress-bar",
  "version": "0.2.0",
  "description": "A minimal and elegant plugin that visualizes your checkbox completion with beautiful progress bars.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node scripts/run-tests.cjs",
    "check:mobile": "node scripts/mobile-ready-check.cjs",
    "check": "npm run test && npm run build && npm run check:mobile && npm run check:release && npm audit --audit-level=moderate",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "check:release": "node scripts/release-metadata-check.cjs"
  },
  "keywords": [
    "obsidian",
    "plugin"
  ],
  "author": "Toby Chen",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pochihh/obsidian-simple-progress-bar.git"
  },
  "bugs": {
    "url": "https://github.com/pochihh/obsidian-simple-progress-bar/issues"
  },
  "homepage": "https://github.com/pochihh/obsidian-simple-progress-bar#readme"
}
